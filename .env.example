# ============================================================
# Bike-Share Operations Platform - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Google Cloud / BigQuery ---
GOOGLE_APPLICATION_CREDENTIALS=credentials/service-account.json
GCP_PROJECT_ID=your-gcp-project-id

# --- Slack Integration ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=YOUR_SLACK_CHANNEL_ID
# SLACK_APP_TOKEN=xapp-your-slack-app-token
# SLACK_SIGNING_SECRET=your-signing-secret

# --- Google Sheets ---
# DEMAND_FORECAST_SHEET_ID=your-google-sheet-id
# ASSET_SHEET_ID=your-asset-tracking-sheet-id
SEARCH_STATUS_SHEET_ID=your-google-sheet-id

# --- Weather API ---
# WEATHER_API_KEY=your-weather-api-key
# WEATHER_FORECAST_API_KEY=your-forecast-api-key

# --- AI / LLM ---
# ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Dashboard Auth (required, no defaults) ---
DEMO_PASSWORD=your-demo-password
ADMIN_PASSWORD=your-admin-password

# --- Return Zone Approval ---
# GMAIL_CREDENTIALS_PATH=credentials/gmail-credentials.json
# GMAIL_TOKEN_PATH=credentials/gmail-token.json
# ADMIN_WEB_USERNAME=your-admin-username
# ADMIN_WEB_PASSWORD=your-admin-password
# ADMIN_WEB_BASE_URL=https://admin.example.com
