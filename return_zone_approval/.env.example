# ===========================================
# 반납구역 승인 워크플로우 환경 설정
# ===========================================
# 이 파일을 .env로 복사하고 실제 값을 입력하세요
# cp .env.example .env

# -------------------------------------------
# Slack 설정
# -------------------------------------------
# Slack Bot Token (xoxb-로 시작)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App Token (xapp-로 시작, Socket Mode용)
SLACK_APP_TOKEN=xapp-your-app-token

# Slack Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# 모니터링할 슬랙 채널 ID (쉼표로 구분)
# 예: C01234567,C76543210
SLACK_MONITOR_CHANNELS=C01234567

# 승인 알림을 보낼 채널 ID 또는 사용자 DM ID
SLACK_APPROVAL_CHANNEL=C01234567

# 승인 알림에서 멘션할 사용자 ID
SLACK_NOTIFY_USER_ID=U01234567

# -------------------------------------------
# Gmail API 설정
# -------------------------------------------
# OAuth 2.0 credentials 파일 경로
GMAIL_CREDENTIALS_PATH=credentials.json

# 토큰 저장 파일 경로
GMAIL_TOKEN_PATH=token.json

# 모니터링할 라벨
GMAIL_MONITOR_LABEL=INBOX

# 허용할 발신자 이메일 (쉼표로 구분, 비어있으면 모두 허용)
GMAIL_ALLOWED_SENDERS=admin@example.com,support@example.com

# 이메일 확인 간격 (초)
GMAIL_POLL_INTERVAL=60

# -------------------------------------------
# Anthropic (Claude) API 설정
# -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-api-key

# 사용할 모델
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -------------------------------------------
# BikeShare 관제웹 설정
# -------------------------------------------
BIKESHARE_BASE_URL=https://admin.example.com
BIKESHARE_USERNAME=your-username
BIKESHARE_PASSWORD=your-password

# headless 모드 (true/false)
BIKESHARE_HEADLESS=true

# 스크린샷 저장 경로
BIKESHARE_SCREENSHOT_DIR=./screenshots

# -------------------------------------------
# 앱 설정
# -------------------------------------------
# TinyDB 데이터베이스 경로
DB_PATH=./data/approval_queue.json

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
